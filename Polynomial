    /* begin ---------- FFT ---------- begin */
    constexpr double PI2 = 6.283185307179586476925286766559005768394338798750211641949889;
    inline std::complex<double> expn(size_t n) { return std::complex<double>(std::cos(PI2 / n), std::sin(PI2 / n)); } // C++ 貌似有原根计算函数，不过都写好了，就这吧
    inline std::complex<double> T2TFFT(double x) { return std::complex<double>(x, 0); }
    inline double TFFT2T(const std::complex<double>& x) { return x.real(); }
    /* end ---------- FFT ---------- end */

    template<typename T = double,
             typename TDFT = std::complex<double>,
             auto UR = expn,
             auto T2TDFT = T2TFFT,
             auto TDFT2T = TFFT2T
             >
    class Polynomial:public std::vector<T> {
    private:
        static T __return1([[maybe_unused]] const T& x) { return T(1); }
        static T __return0([[maybe_unused]] const T& x) { return T(0); }
        static std::vector<TDFT>& get_unit_roots() { thread_local static std::vector<TDFT> unitRoots = {TDFT(1)}; return unitRoots; }
        static size_t& get_root_size() { thread_local static size_t sz = 1; return sz; }
        static void ensure_precomputed(size_t n) {
            auto& unitRoots = get_unit_roots(); auto& sz = get_root_size();
            if (sz < n) {
                unitRoots.resize(n);
                do {
                    const TDFT wn = UR(sz << 2);
                    for (size_t i = 0; i < sz; ++i) unitRoots[sz + i] = unitRoots[i] * wn;
                    sz <<= 1;
                } while (sz < n);
            }
        }
        #define LEN_THRESHOLD0 4096
        #define LEN_THRESHOLD1 16777216
        inline void DFTIteration(typename std::vector<TDFT>::iterator l, typename std::vector<TDFT>::iterator r, size_t id = 0) {
            auto& unitRoots = get_unit_roots();
            for(size_t l2 = (r - l) >> 1; l2; l2 >>= 1, id <<= 1)
                for(auto i = l, ww = unitRoots.begin() + id; i != r; i += l2 << 1, ++ww) {
                    auto &w = *ww;
                    for(auto uu = i, vv = i + l2; uu != i + l2; ++uu, ++vv) {
                        auto &u = *uu, &v = *vv; auto temp = v * w;
                        std::tie(u, v) = std::pair{u + temp, u - temp};
                    }
                }
        }
        inline void IDFTIteration(typename std::vector<TDFT>::iterator l, typename std::vector<TDFT>::iterator r, size_t id = 0) {
            auto& unitRoots = get_unit_roots(); const size_t n = r - l;
            id <<= log2Floor(n) - 1;
            for(size_t l2 = 1; l2 < n; l2 <<= 1, id >>= 1)
                for(auto i = l, ww = unitRoots.begin() + id; i != r; i += l2 << 1, ++ww) {
                    auto &w = *ww;
                    for(auto uu = i, vv = i + l2; uu != i + l2; ++uu, ++vv) {
                        auto &u = *uu, &v = *vv;
                        std::tie(u, v) = std::pair{u + v, (u - v) * w};
                    }
                }
        }
        template<size_t n>
        inline void DFTRecursion(typename std::vector<TDFT>::iterator l, typename std::vector<TDFT>::iterator r, size_t id = 0) {
            if constexpr (n <= LEN_THRESHOLD0) DFTIteration(l, r, id);
            else {
                auto mid = l + ((r - l) >> 1);
                for (auto i = l, j = mid, w = get_unit_roots()[id]; j != r; ++i, ++j) {
                    auto &u = *i, &v = *j; auto temp = v * w;
                    std::tie(u, v) = std::pair{u + temp, u - temp};
                }
                id <<= 1;
                constexpr size_t m = n >> 1;
                DFTRecursion<m>(l, mid, id);
                DFTRecursion<m>(mid, r, id | 1);
            }
        }
        template<size_t n>
        inline void IDFTRecursion(typename std::vector<TDFT>::iterator l, typename std::vector<TDFT>::iterator r, size_t id = 0) {
            if constexpr (n <= LEN_THRESHOLD0) IDFTIteration(l, r, id);
            else {
                constexpr size_t m = n >> 1;
                auto mid = l + ((r - l) >> 1);
                IDFTRecursion<m>(l, mid, id << 1);
                IDFTRecursion<m>(mid, r, id << 1 | 1);
                for (auto w = get_unit_roots()[id]; mid != r; ++l, ++mid) {
                    auto &u = *l, &v = *mid;
                    std::tie(u, v) = std::pair{u + v, (u - v) * w};
                }
            }
        }
        inline void DFT(typename std::vector<TDFT>::iterator l, typename std::vector<TDFT>::iterator r) {
            auto& unitRoots = get_unit_roots();
            size_t n = r - l;
            for(size_t l2 = n >> 1; l2 >= LEN_THRESHOLD1; l2 >>= 1)
                for(auto i = l, ww = unitRoots.begin(); i != r; i += l2 << 1, ++ww) {
                    auto &w = *ww;
                    for(auto uu = i, vv = i + l2; uu != i + l2; ++uu, ++vv) {
                        auto &u = *uu, &v = *vv; auto temp = v * w;
                        std::tie(u, v) = std::pair{u + temp, u - temp};
                    }
                }
            if (n > LEN_THRESHOLD1) {
                size_t idx = 0;
                for (auto i = l; i != r; i += LEN_THRESHOLD1, ++idx) DFTRecursion<LEN_THRESHOLD1>(i, i + LEN_THRESHOLD1,idx);
            } else switch (n) {case 128:{DFTRecursion<128>(l, r);break;}case 256:{DFTRecursion<256>(l, r);break;}case 512:{DFTRecursion<512>(l, r);break;}case 1024:{DFTRecursion<1024>(l, r);break;}case 2048:{DFTRecursion<2048>(l, r);break;}case 4096:{DFTRecursion<4096>(l, r);break;}case 8192:{DFTRecursion<8192>(l, r);break;}case 16384:{DFTRecursion<16384>(l, r);break;}case 32768:{DFTRecursion<32768>(l, r);break;}case 65536:{DFTRecursion<65536>(l, r);break;}case 131072:{DFTRecursion<131072>(l, r);break;}case 262144:{DFTRecursion<262144>(l, r);break;}case 524288:{DFTRecursion<524288>(l, r);break;}case 1048576:{DFTRecursion<1048576>(l, r);break;}case 2097152:{DFTRecursion<2097152>(l, r);break;}case 4194304:{DFTRecursion<4194304>(l, r);break;}case 8388608:{DFTRecursion<8388608>(l, r);break;}case 16777216:{DFTRecursion<16777216>(l, r);break;}}
        }
        inline void IDFT(typename std::vector<TDFT>::iterator l, typename std::vector<TDFT>::iterator r) {
            auto& unitRoots = get_unit_roots();
            size_t n = r - l;
            if (n > LEN_THRESHOLD1) {
                size_t idx = 0;
                for (auto i = l; i != r; i += LEN_THRESHOLD1, ++idx) IDFTRecursion<LEN_THRESHOLD1>(i, i + LEN_THRESHOLD1,idx);;
            } else switch (n) {case 128:{IDFTRecursion<128>(l, r);break;}case 256:{IDFTRecursion<256>(l, r);break;}case 512:{IDFTRecursion<512>(l, r);break;}case 1024:{IDFTRecursion<1024>(l, r);break;}case 2048:{IDFTRecursion<2048>(l, r);break;}case 4096:{IDFTRecursion<4096>(l, r);break;}case 8192:{IDFTRecursion<8192>(l, r);break;}case 16384:{IDFTRecursion<16384>(l, r);break;}case 32768:{IDFTRecursion<32768>(l, r);break;}case 65536:{IDFTRecursion<65536>(l, r);break;}case 131072:{IDFTRecursion<131072>(l, r);break;}case 262144:{IDFTRecursion<262144>(l, r);break;}case 524288:{IDFTRecursion<524288>(l, r);break;}case 1048576:{IDFTRecursion<1048576>(l, r);break;}case 2097152:{IDFTRecursion<2097152>(l, r);break;}case 4194304:{IDFTRecursion<4194304>(l, r);break;}case 8388608:{IDFTRecursion<8388608>(l, r);break;}case 16777216:{IDFTRecursion<16777216>(l, r);break;}}
            for(size_t l2 = LEN_THRESHOLD1; l2 < n; l2 <<= 1)
                for(auto i = l, ww = unitRoots.begin(); i != r; i += l2 << 1, ++ww) {
                    auto &w = *ww;
                    for(auto uu = i, vv = i + l2; uu != i + l2; ++uu, ++vv) {
                        auto &u = *uu, &v = *vv;
                        std::tie(u, v) = std::pair{u + v, (u - v) * w};
                    }
                }
            std::reverse(l + 1, r);
        }
        #undef LEN_THRESHOLD0
        #undef LEN_THRESHOLD1
    public:
        static void clearCache() {
            get_unit_roots().clear();
            get_unit_roots().shrink_to_fit();
            get_unit_roots().push_back(TDFT(1));
            get_root_size() = 1;
        }
        using std::vector<T>::operator[];
        Polynomial(const size_t& n = 0, const T& x = T(0)): std::vector<T>(n, x) {}
        Polynomial(const Polynomial& o): std::vector<T>(o) {}
        Polynomial(Polynomial&& o) noexcept = default;
        Polynomial& operator=(const Polynomial& o) {
            this->resize(o.size());
            for (auto i = this->begin(), j = o.begin(); i != this->end(); ++i, ++j) (*i) = (*j);
            return *this;
        }
        Polynomial& operator=(Polynomial&& o) noexcept = default;
        ~Polynomial() = default;
        Polynomial derivative() const {
            if (this->empty()) return Polynomial();
            Polynomial res(this->size() - 1, 0);
            for (size_t i = 0; i < res.size(); i++) res[i] = T(i + 1) * operator[](i + 1);
            return std::move(res);
        }
        Polynomial integral() const {
            Polynomial res(this->size() + 1);
            for (size_t i = 1; i < res.size(); i++) res[i] = operator[](i - 1) / T(i);
            return std::move(res);
        }
        Polynomial& derivativeSelf() {
            if (this->empty()) return *this;
            for (size_t i = 0; i < this->size() - 1; i++) operator[](i) = T(i + 1) * operator[](i + 1);
            this->pop_back();
            return *this;
        }
        Polynomial& integralSelf() {
            this->push_back(T(0));
            for (size_t i = this->size() - 1; i > 0; i--) operator[](i) = operator[](i - 1) / T(i);
            this->front() = T(0);
            return *this;
        }
        T calcIntegral(const T& x) const {
            T tmp(x), res(0);
            for (size_t i = 0; i < this->size(); i++, tmp *= x) res += operator[](i) / T(i + 1) * tmp; 
            return std::move(res);
        }
        T calcDerivative(const T &x) const {
            T tmp(1), res(0);
            for (size_t i = 1; i < this->size(); i++, tmp *= x) res += operator[](i) * T(i) * tmp;
            return std::move(res);
        }
        T calc(const T &x) {
            T tmp(1), res(0);
            for (auto i = this->begin(); i != this->end(); ++i, tmp *= x) res += (*i) * tmp;
            return std::move(res);
        }
        Polynomial operator+(const Polynomial& o) const {
            Polynomial res(*this);
            if (this->size() < o.size()) res.resize(o.size(), T(0));
            for (auto i = res.begin(), j = o.begin(); j != o.end(); ++i, ++j) (*i) += (*j);
            return std::move(res);
        }
        Polynomial& operator+=(const Polynomial& o) {
            if (this->size() < o.size()) this->resize(o.size(), T(0));
            for (auto i = this->begin(), j = o.begin(); j != o.end(); ++i, ++j) (*i) += (*j);
            return *this;
        }
        Polynomial operator-(const Polynomial& o) const {
            Polynomial res(*this);
            if (this->size() < o.size()) res.resize(o.size(), T(0));
            for (auto i = res.begin(), j = o.begin(); j != o.end(); ++i, ++j) (*i) -= (*j);
            return std::move(res);
        }
        Polynomial& operator-=(const Polynomial& o) {
            if (this->size() < o.size()) this->resize(o.size(), T(0));
            for (auto i = this->begin(), j = o.begin(); j != o.end(); ++i, ++j) (*i) -= (*j);
            return *this;
        }
        Polynomial operator*(const T& o) const {
            Polynomial res(*this);
            for (auto& i: res) i *= o;
            return std::move(res);
        }
        Polynomial& operator*=(const T& o) {
            for (auto& i: *this) i *= o;
            return *this;
        }
        Polynomial operator/(const T& o) const {
            Polynomial res(*this);
            o = T(1) / o;
            for (auto& i: res) i *= o;
            return std::move(res);
        }
        Polynomial& operator/=(const T& o) {
            o = T(1) / o;
            for (auto& i: *this) i *= o;
            return *this;
        }
        Polynomial& operator*=(const Polynomial& o) {
            if (std::min(this->size(), o.size()) <= 64) {
                if (this->empty() || o.empty()) return *this = Polynomial(0, T(0));
                Polynomial res(this->size() + o.size() - 1, T(0));
                auto p = res.begin();
                for (auto i = this->begin(); i != this->end(); ++i, ++p) {
                    auto k = p;
                    for (auto j = o.begin(); j != o.end(); ++j, ++k) (*k) += (*i) * (*j);
                }
                return *this = std::move(res);
            }
            const size_t n = size_t(1) << log2Ceil(this->size() + o.size() - 1);
            ensure_precomputed(n);
            if (this == &o) {
                if constexpr (std::is_same<TDFT, T>::value) {
                    const size_t len = this->size() + o.size() - 1;
                    this->resize(n, T(0));
                    DFT(this->begin(), this->end());
                    for (auto& i : *this) i *= i;
                    IDFT(this->begin(), this->end());
                    this->resize(len);
                    const TDFT div = TDFT(1) / TDFT(n);
                    for (auto& i : *this) i *= div;
                    return *this;
                } else {
                    std::vector<TDFT> a(n);
                    {
                        auto j = a.begin();
                        for (auto i = this->begin(); i != this->end(); ++i, ++j) (*j) = T2TDFT(*i);
                    }
                    DFT(a.begin(), a.end());
                    for (auto& i : a) i *= i;
                    IDFT(a.begin(), a.end());
                    this->resize(this->size() + o.size() - 1, T(0));
                    const TDFT div = TDFT(1) / TDFT(n);
                    for (size_t i = 0; i < this->size(); i++) operator[](i) = TDFT2T(a[i] * div);
                    return *this;
                }
            }
            if constexpr (std::is_same<TDFT, std::complex<T>>::value) {
                std::vector<std::complex<T>> a(n);
                {
                    auto j = a.begin();
                    for (auto i = this->begin(); i != this->end(); ++i, ++j) j->real(*i);
                }
                {
                    auto j = a.begin();
                    for (auto i = o.begin(); i != o.end(); ++i, ++j) j->imag(*i);
                }
                DFT(a.begin(), a.end());
                for (auto& i : a) i *= i;
                IDFT(a.begin(), a.end());
                this->resize(this->size() + o.size() - 1, T(0));
                const T div = T(1) / T(n << 1);
                for (size_t i = 0; i < this->size(); i++) operator[](i) = a[i].imag() * div;
                return *this;
            } else {
                if constexpr (std::is_same<T, TDFT>::value) {
                    const size_t len = this->size() + o.size() - 1;
                    this->resize(n, T(0));
                    std::vector<TDFT> b(o); b.resize(n, T(0));
                    DFT(this->begin(), this->end()), DFT(b.begin(), b.end());
                    for (auto i = this->begin(), j = b.begin(); i != this->end(); ++i, ++j) (*i) *= (*j);
                    IDFT(this->begin(), this->end());
                    this->resize(len);
                    const TDFT div = TDFT(1) / TDFT(n);
                    for (auto& i : *this) i *= div;
                    return *this;
                } else {
                    std::vector<TDFT> a(n), b(n);
                    {
                        auto j = a.begin();
                        for (auto i = this->begin(); i != this->end(); ++i, ++j) (*j) = T2TDFT(*i);
                    }
                    {
                        auto j = b.begin();
                        for (auto i = o.begin(); i != o.end(); ++i, ++j) (*j) = T2TDFT(*i);
                    }
                    DFT(a.begin(), a.end()), DFT(b.begin(), b.end());
                    for (auto i = a.begin(), j = b.begin(); i != a.end(); ++i, ++j) (*i) *= (*j);
                    IDFT(a.begin(), a.end());
                    this->resize(this->size() + o.size() - 1, T(0));
                    const TDFT div = TDFT(1) / TDFT(n);
                    for (size_t i = 0; i < this->size(); i++) operator[](i) = TDFT2T(a[i] * div);
                    return *this;
                }
            }
        }
        Polynomial operator*(const Polynomial& o) const {
            Polynomial res(*this);
            if (this == &o) return std::move(res *= res);
            else return std::move(res *= o);
        }
        Polynomial operator%(size_t n) const {
            Polynomial res(*this);
            res.resize(n);
            return std::move(res);
        }
        Polynomial& operator%=(size_t n) {
            this->resize(n);
            return *this;
        }
        Polynomial inv() const {
            Polynomial res(1, T(1) / this->front()), tmp(1, this->front());
            while (res.size() < this->size()) {
                tmp.resize(std::min(this->size(), res.size() << 1), T(0));
                for (auto i = tmp.begin() + res.size(), j = this->begin() + res.size(); i != tmp.end(); ++i, ++j) (*i) = (*j);
                (res += res - res * res * tmp) %= tmp.size();
            }
            return std::move(res);
        }
        Polynomial& invSelf() {
            Polynomial res(1, T(1) / this->front()), tmp(1, this->front());
            while (res.size() < this->size()) {
                tmp.resize(std::min(this->size(), res.size() << 1), T(0));
                for (auto i = tmp.begin() + res.size(), j = this->begin() + res.size(); i != tmp.end(); ++i, ++j) (*i) = (*j);
                (res += res - res * res * tmp) %= tmp.size();
            }
            return *this = std::move(res);
        }
        template<auto LN = __return0>
        Polynomial ln() const { 
            auto res = *this;
            auto frt = res.front(), inv = T(1) / frt;
            for (auto& i : res) i *= inv;
            return std::move(((res.derivative() * res.inv()).integralSelf() += Polynomial(1, LN(frt))) %= this->size());
            // 我也不知道为什么这样写是可行的，并没有出问题就留着了，有问题了化可以提出修改建议
        }
        template<auto LN = __return0>
        Polynomial& lnSelf() {
            auto frt = this->front(), inv = T(1) / frt;
            for (auto& i : *this) i *= inv;
            size_t n = this->size();
            *this = this->derivative() * this->inv();
            return (this->integralSelf() += Polynomial(1, LN(frt))) %= n;
        }
        template<auto EXP = __return1>
        Polynomial exp() const {
            if (this->empty()) return Polynomial(0, T(0));
            Polynomial res(1, EXP(this->front())), tmp(1, this->front());
            while (res.size() < this->size()) {
                tmp.resize(std::min(this->size(), res.size() << 1), T(0));
                for (auto i = tmp.begin() + res.size(), j = this->begin() + res.size(); i != tmp.end(); ++i, ++j) (*i) = (*j);
                (res += res * (tmp - (res % tmp.size()).ln())) %= tmp.size();
            }
            return std::move(res);
        }
        template<auto EXP = __return1>
        Polynomial& expSelf() {
            if (this->empty()) return *this = Polynomial(0, T(0));
            Polynomial res(1, EXP(this->front())), tmp(1, this->front());
            while (res.size() < this->size()) {
                tmp.resize(std::min(this->size(), res.size() << 1), T(0));
                for (auto i = tmp.begin() + res.size(), j = this->begin() + res.size(); i != tmp.end(); ++i, ++j) (*i) = (*j);
                (res += res * (tmp - (res % tmp.size()).ln())) %= tmp.size();
            }
            return *this = std::move(res);
        }
        template<auto SQRT = __return1>
        Polynomial sqrt() const {
            if (this->empty()) return Polynomial(0, T(0));
            Polynomial res(1, SQRT(this->front())), tmp(1, this->front());
            while (res.size() < this->size()) {
                tmp.resize(std::min(this->size(), res.size() << 1), T(0));
                for (auto i = tmp.begin() + res.size(), j = this->begin() + res.size(); i != tmp.end(); ++i, ++j) (*i) = (*j);
                (res = (tmp + res * res) * ((res + res) % tmp.size()).inv()) %= tmp.size();
            }
            return std::move(res);
        }
        template<auto SQRT = __return1>
        Polynomial& sqrtSelf() {
            if (this->empty()) return *this = Polynomial(0, T(0));
            Polynomial res(1, SQRT(this->front())), tmp(1, this->front());
            while (res.size() < this->size()) {
                tmp.resize(std::min(this->size(), res.size() << 1), T(0));
                for (auto i = tmp.begin() + res.size(), j = this->begin() + res.size(); i != tmp.end(); ++i, ++j) (*i) = (*j);
                (res = (tmp + res * res) * ((res + res) % tmp.size()).inv()) %= tmp.size();
            }
            return *this = std::move(res); 
        }
        template<typename U>
        Polynomial& powSelf(U n, U m = U(-1)) {
